# 应用配置
APP_NAME="GPT Team 管理系统"
APP_VERSION="0.1.0"
APP_HOST="0.0.0.0"
APP_PORT=8008
DEBUG=True
# Zeabur 会自动注入 PORT，通常不需要手动配置 APP_PORT

# 数据库配置
DATABASE_URL="sqlite+aiosqlite:///./team_manage.db"
# Zeabur 部署建议改为 sqlite+aiosqlite:////app/data/team_manage.db，并为 /app/data 挂载持久化卷

# 安全配置
SECRET_KEY="your-secret-key-here-change-in-production"
ADMIN_PASSWORD="admin123"  # 首次启动后请修改
# Zeabur 生产环境请在平台环境变量中单独配置 SECRET_KEY / ADMIN_PASSWORD，不依赖 .env 文件挂载

# 日志配置
LOG_LEVEL="INFO"  # DEBUG, INFO, WARNING, ERROR, CRITICAL
DATABASE_ECHO=False  # 是否打印 SQL 语句

# 代理配置 (可选)
PROXY=""  # 格式: http://host:port、https://host:port、socks5://host:port、socks5h://host:port 或 socks5://user:pass@host:port
PROXY_ENABLED=False

# JWT 配置
JWT_VERIFY_SIGNATURE=False  # 开发环境可设为 False,生产环境建议设为 True

# 时区配置
TIMEZONE=Asia/Shanghai  # 默认使用中国时区
